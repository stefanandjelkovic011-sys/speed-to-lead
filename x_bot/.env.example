# ─── X (Twitter) API v2 Credentials ──────────────────────────────────────
# Get these from https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# ─── X Account Credentials (for Playwright browser bridge) ──────────────
# Only needed if USE_BROWSER=true
X_USERNAME=your_twitter_handle
X_PASSWORD=your_twitter_password

# ─── Anthropic (Claude) API Key ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Bot Settings ────────────────────────────────────────────────────────
# Set to "true" to print posts without actually sending them
DRY_RUN=true

# Set to "true" to use Playwright browser directly (no API credits)
USE_BROWSER=false

# Set to "true" to use Claude CLI + Playwright MCP bridge (no API credits, smartest option)
USE_MCP=false
